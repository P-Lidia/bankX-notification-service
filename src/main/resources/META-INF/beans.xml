<?xml version="1.0" encoding="UTF-8"?>
<!--
  Конфигурационный файл CDI (Contexts and Dependency Injection) для Jakarta EE
  Этот файл активирует и настраивает систему внедрения зависимостей в приложении
-->

<beans xmlns="https://jakarta.ee/xml/ns/jakartaee"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                           https://jakarta.ee/xml/ns/jakartaee/beans_3_0.xsd"
       version="3.0" bean-discovery-mode="all">

    <!--
      bean-discovery-mode="all" - режим обнаружения бинов:
        - "all": CDI будет сканировать все классы в приложении и автоматически
                  регистрировать все классы с соответствующими аннотациями как бины
        - "annotated": только классы с CDI-аннотациями будут зарегистрированы
        - "none": отключает автоматическое обнаружение бинов

      В данном случае используется режим "all", что означает:
        - Все классы с аннотациями @Inject, @Produces, @Named и другими
          CDI-аннотациями будут автоматически управляться контейнером
        - Это наиболее простой и удобный режим для большинства приложений
    -->

    <!--
      Дополнительные настройки могут быть добавлены здесь:
        - Альтернативы (alternatives) для замены реализации в разных профилях
        - Интерцепторы (interceptors) для сквозной функциональности
        - Декораторы (decorators) для расширения функциональности бинов
        - События (events) и наблюдатели (observers)
    -->

</beans>